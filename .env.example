# ===========================================================
# .env 
# ===========================================================
# This file defines local environment variables used by the Taskfile.
# DO NOT commit this file to Git.
# Replace placeholder values (XXXX...) with your actual IDs or tokens.
# ===========================================================

# -----------------------------------------------------------
# General environment
# -----------------------------------------------------------
ENV=dev                        # Logical environment name (dev/stg/prd etc.)
TF_DIR=infra/workload-azure              # Default Terraform working directory
PLAN=plan.bin                   # Terraform plan output file

# -----------------------------------------------------------
# Azure authentication (Service Principal / OIDC context)
# -----------------------------------------------------------
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx          # Tenant ID (Entra ID)
AZURE_SUBSCRIPTION_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Subscription ID
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx          # (Optional) App registration / SP client ID
SP_OBJ_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====== Variables (replace with your own values) ======
TENANT_ID="<your-tenant-id>"
SUB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TFSTATE_RG_NAME=rg-tfstate
APP_NAME=gha-oidc-terraform
REPO=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx            # e.g., nobhri/azure-dbx-mock-platform
BRANCH="refs/heads/main"
TFSTATE_SA_ID=/subscriptions/xxxxxxxxxxxxx/resourceGroups/rg-tfstate/providers/Microsoft.Storage/storageAccounts/<storage account name>
TFSTATE_SA_NAME=stabcdtfstate
TFSTATE_CONTAINER=workload-tfstate
# TFSTATE_KEY=

# If you use client secret auth (NOT recommended for CI):
# AZURE_CLIENT_SECRET=your-client-secret

# -----------------------------------------------------------
# Databricks workspace access
# -----------------------------------------------------------
DATABRICKS_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
METASTORE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DATABRICKS_HOST=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Short-lived PAT for local dev only.
# In CI/CD, prefer OIDC or M2M service principal instead.

# Optional: predefine a SQL Warehouse ID to simplify SQL queries
DATABRICKS_WAREHOUSE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx 

# -----------------------------------------------------------
# Additional tools or defaults
# -----------------------------------------------------------
# Terraform & lint settings
TF_LOG=ERROR                   # Logging level (INFO / DEBUG for troubleshooting)
TF_IN_AUTOMATION=true           # Non-interactive mode
TFLINT_CONFIG=.tflint.hcl       # Path to TFLint config if exists

# -----------------------------------------------------------
# Notes:
# - Keep this file out of version control (add ".env" to .gitignore)
# - Use "task check:env" to verify required variables.
# - You can override any value at runtime:
#     task plan TF_DIR=infra/databricks ENV=stg
# - Never share PAT or secrets. Rotate them frequently.
# -----------------------------------------------------------
